#!/usr/bin/env sh

APP_HOME=$(cd "$(dirname "$0")" >/dev/null 2>&1 && pwd)
JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"

if [ ! -f "$JAR" ]; then
  echo "Gradle wrapper jar is missing: $JAR" >&2
  echo "Install Gradle or regenerate the wrapper with: gradle wrapper --gradle-version 8.10.2" >&2
  exit 1
fi

exec java -cp "$JAR" org.gradle.wrapper.GradleWrapperMain "$@"
